@page "{id:int}"
@model CinemaApp.Web.Pages.Films.EditModel
@{ ViewData["Title"] = "Редактирай филм"; }

<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-warning text-dark">
        <h5 class="mb-0"><i class="bi bi-pencil me-2"></i>Редактирай филм</h5>
      </div>
      <div class="card-body">
        <form method="post">
          <input asp-for="Film.FilmId" type="hidden" />
          <div class="mb-3">
            <label asp-for="Film.FilmName" class="form-label">Заглавие</label>
            <input asp-for="Film.FilmName" class="form-control" />
            <span asp-validation-for="Film.FilmName" class="text-danger small"></span>
          </div>
          <div class="mb-3">
            <label asp-for="Film.FilmGenre" class="form-label">Жанр</label>
            <input asp-for="Film.FilmGenre" class="form-control" />
            <span asp-validation-for="Film.FilmGenre" class="text-danger small"></span>
          </div>
          <div class="mb-3">
            <label asp-for="Film.FilmTime" class="form-label">Времетраене (минути)</label>
            <input asp-for="Film.FilmTime" class="form-control" type="number" step="0.5" />
            <span asp-validation-for="Film.FilmTime" class="text-danger small"></span>
          </div>
          <div class="mb-3">
            <label asp-for="Film.ActorId" class="form-label">Актьор</label>
            <select asp-for="Film.ActorId" asp-items="Model.ActorsList" class="form-select">
              <option value="">-- Избери актьор --</option>
            </select>
          </div>
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-warning"><i class="bi bi-save me-1"></i>Запази</button>
            <a href="/Films" class="btn btn-outline-secondary">Отказ</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
