@page
@model CinemaApp.Web.Pages.Films.ShortestModel
@{ ViewData["Title"] = "Най-кратки 3 филма"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-sort-numeric-up me-2 text-success"></i>Най-кратките 3 филма</h2>
    <a href="/Films" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Обратно</a>
</div>

<div class="card shadow-sm border-0">
  <div class="card-body p-0">
    <table class="table table-hover mb-0">
      <thead class="table-dark">
        <tr><th>Заглавие</th><th>Жанр</th><th>Мин.</th><th>Актьор</th></tr>
      </thead>
      <tbody>
        @foreach (var f in Model.Films)
        {
          <tr>
            <td class="fw-semibold">@f.FilmName</td>
            <td><span class="badge bg-info text-dark">@f.FilmGenre</span></td>
            <td>@f.FilmTime</td>
            <td>@f.Actor?.FirstName @f.Actor?.LastName</td>
          </tr>
        }
      </tbody>
    </table>
  </div>
</div>
