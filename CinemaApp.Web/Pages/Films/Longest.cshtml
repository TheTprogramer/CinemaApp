@page
@model CinemaApp.Web.Pages.Films.LongestModel
@{ ViewData["Title"] = "Най-дълъг филм"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-sort-numeric-down me-2 text-success"></i>Най-дълъг филм</h2>
    <a href="/Films" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Обратно</a>
</div>

@if (Model.Film == null)
{
    <div class="alert alert-warning">Няма филми в базата.</div>
}
else
{
    <div class="card shadow-sm border-0 col-md-6">
      <div class="card-header bg-success text-white">
        <h5 class="mb-0"><i class="bi bi-trophy me-2"></i>@Model.Film.FilmName</h5>
      </div>
      <div class="card-body">
        <dl class="row mb-0">
          <dt class="col-sm-4">Жанр:</dt>
          <dd class="col-sm-8"><span class="badge bg-info text-dark">@Model.Film.FilmGenre</span></dd>
          <dt class="col-sm-4">Времетраене:</dt>
          <dd class="col-sm-8 fw-bold text-success">@Model.Film.FilmTime мин.</dd>
          <dt class="col-sm-4">Актьор:</dt>
          <dd class="col-sm-8">@Model.Film.Actor?.FirstName @Model.Film.Actor?.LastName</dd>
        </dl>
      </div>
    </div>
}
