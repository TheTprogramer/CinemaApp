@page
@model CinemaApp.Web.Pages.Films.WithDetailsModel
@{ ViewData["Title"] = "Филми с детайли"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-info-circle me-2 text-info"></i>Филми с актьори и прожекции</h2>
    <a href="/Films" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Обратно</a>
</div>

@foreach (var f in Model.Films)
{
    <div class="card shadow-sm border-0 mb-3">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <span class="fw-bold"><i class="bi bi-film me-2"></i>@f.FilmName</span>
            <div>
                <span class="badge bg-info text-dark me-2">@f.FilmGenre</span>
                <span class="badge bg-secondary">@f.FilmTime мин.</span>
            </div>
        </div>
        <div class="card-body">
            <p class="mb-2 text-muted">
                <i class="bi bi-person me-1"></i>
                <strong>Актьор:</strong> @f.Actor?.FirstName @f.Actor?.LastName
            </p>
            @if (!f.Projects.Any())
            {
                <p class="text-muted mb-0">Няма прожекции.</p>
            }
            else
            {
                <table class="table table-sm mb-0">
                    <thead class="table-light">
                        <tr><th>Ден</th><th>Начало</th><th>Край</th><th>Зала</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var p in f.Projects)
                        {
                            <tr>
                                <td>@p.DayOfWeek</td>
                                <td>@p.StartTime</td>
                                <td>@p.EndTime</td>
                                <td><span class="badge bg-primary">@p.Room?.RoomType</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}
