@page "{id:int}"
@model CinemaApp.Web.Pages.Actors.DeleteModel
@{ ViewData["Title"] = "Изтрий актьор"; }

<div class="row justify-content-center">
  <div class="col-md-5">
    <div class="card shadow-sm border-2 border-danger">
      <div class="card-header bg-danger text-white">
        <h5 class="mb-0"><i class="bi bi-trash me-2"></i>Изтрий актьор</h5>
      </div>
      <div class="card-body">
        <p class="lead">Сигурни ли сте, че искате да изтриете?</p>
        <dl class="row">
          <dt class="col-sm-4">Ime:</dt>
          <dd class="col-sm-8 fw-bold">@Model.Actor.FirstName @Model.Actor.LastName</dd>
          <dt class="col-sm-4">Възраст:</dt>
          <dd class="col-sm-8">@Model.Actor.Age</dd>
        </dl>
        <form method="post">
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Изтрий</button>
            <a href="/Actors" class="btn btn-outline-secondary">Отказ</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
