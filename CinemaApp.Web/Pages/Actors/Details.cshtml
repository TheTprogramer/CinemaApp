@page "{id:int}"
@model CinemaApp.Web.Pages.Actors.DetailsModel
@{ ViewData["Title"] = "Детайли – Актьор"; }

<div class="row justify-content-center">
  <div class="col-md-5">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-info text-white">
        <h5 class="mb-0"><i class="bi bi-person-badge me-2"></i>@Model.Actor.FirstName @Model.Actor.LastName</h5>
      </div>
      <div class="card-body">
        <dl class="row">
          <dt class="col-sm-4">ID:</dt><dd class="col-sm-8">@Model.Actor.ActorId</dd>
          <dt class="col-sm-4">Собствено:</dt><dd class="col-sm-8">@Model.Actor.FirstName</dd>
          <dt class="col-sm-4">Фамилно:</dt><dd class="col-sm-8">@Model.Actor.LastName</dd>
          <dt class="col-sm-4">Възраст:</dt><dd class="col-sm-8">@Model.Actor.Age</dd>
        </dl>
        <div class="d-flex gap-2 mt-3">
          <a href="/Actors/Edit/@Model.Actor.ActorId" class="btn btn-warning">
            <i class="bi bi-pencil me-1"></i>Редактирай
          </a>
          <a href="/Actors" class="btn btn-outline-secondary">Обратно</a>
        </div>
      </div>
    </div>
  </div>
</div>
