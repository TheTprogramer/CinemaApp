@page
@model CinemaApp.Web.Pages.Actors.CreateModel
@{ ViewData["Title"] = "Добави актьор"; }

<div class="row justify-content-center">
  <div class="col-md-5">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-primary text-white">
        <h5 class="mb-0"><i class="bi bi-person-plus me-2"></i>Добави актьор</h5>
      </div>
      <div class="card-body">
        <form method="post">
          <div class="mb-3">
            <label asp-for="Actor.FirstName" class="form-label">Собствено ime</label>
            <input asp-for="Actor.FirstName" class="form-control" />
            <span asp-validation-for="Actor.FirstName" class="text-danger small"></span>
          </div>
          <div class="mb-3">
            <label asp-for="Actor.LastName" class="form-label">Фамилно ime</label>
            <input asp-for="Actor.LastName" class="form-control" />
            <span asp-validation-for="Actor.LastName" class="text-danger small"></span>
          </div>
          <div class="mb-3">
            <label asp-for="Actor.Age" class="form-label">Възраст</label>
            <input asp-for="Actor.Age" class="form-control" type="number" min="1" max="120" />
            <span asp-validation-for="Actor.Age" class="text-danger small"></span>
          </div>
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Запази</button>
            <a href="/Actors" class="btn btn-outline-secondary">Отказ</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
