@page
@model CinemaApp.Web.Pages.Tickets.CreateModel
@{ ViewData["Title"] = "Добави билет"; }

<div class="row justify-content-center">
  <div class="col-md-4">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-danger text-white">
        <h5 class="mb-0"><i class="bi bi-ticket-perforated me-2"></i>Добави билет</h5>
      </div>
      <div class="card-body">
        <form method="post">
          <div class="mb-3">
            <label asp-for="Ticket.TicketPrice" class="form-label">Цена (лв.)</label>
            <input asp-for="Ticket.TicketPrice" class="form-control" type="number" step="0.5" min="0" />
            <span asp-validation-for="Ticket.TicketPrice" class="text-danger small"></span>
          </div>
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger"><i class="bi bi-save me-1"></i>Запази</button>
            <a href="/Tickets" class="btn btn-outline-secondary">Отказ</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
