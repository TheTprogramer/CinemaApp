@page
@model CinemaApp.Web.Pages.Tickets.TotalSumModel
@{ ViewData["Title"] = "Обща сума на билетите"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-cash-coin me-2 text-success"></i>Обща сума на продадените билети</h2>
    <a href="/Tickets" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Обратно</a>
</div>

<div class="row justify-content-center">
  <div class="col-md-5">
    <div class="card shadow-sm border-0 text-center">
      <div class="card-body py-5">
        <i class="bi bi-cash-stack display-3 text-success mb-3"></i>
        <h3 class="text-muted">Обща сума</h3>
        <p class="display-4 fw-bold text-success">@Model.Total.ToString("F2") лв.</p>
        <p class="text-muted small">Сума на всички билети, закупени от клиенти.</p>
      </div>
    </div>
  </div>
</div>
