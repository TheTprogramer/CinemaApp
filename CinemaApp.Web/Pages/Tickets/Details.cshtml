@page "{id:int}"
@model CinemaApp.Web.Pages.Tickets.DetailsModel
@{ ViewData["Title"] = "Детайли – Билет"; }

<div class="row justify-content-center">
  <div class="col-md-4">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-info text-white">
        <h5 class="mb-0"><i class="bi bi-ticket-perforated me-2"></i>Билет #@Model.Ticket.TicketId</h5>
      </div>
      <div class="card-body">
        <dl class="row">
          <dt class="col-sm-4">ID:</dt><dd class="col-sm-8">@Model.Ticket.TicketId</dd>
          <dt class="col-sm-4">Цена:</dt>
          <dd class="col-sm-8 fw-bold text-success fs-5">@Model.Ticket.TicketPrice.ToString("F2") лв.</dd>
        </dl>
        <div class="d-flex gap-2 mt-3">
          <a href="/Tickets/Edit/@Model.Ticket.TicketId" class="btn btn-warning">
            <i class="bi bi-pencil me-1"></i>Редактирай
          </a>
          <a href="/Tickets" class="btn btn-outline-secondary">Обратно</a>
        </div>
      </div>
    </div>
  </div>
</div>
