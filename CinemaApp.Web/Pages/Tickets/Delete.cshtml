@page "{id:int}"
@model CinemaApp.Web.Pages.Tickets.DeleteModel
@{ ViewData["Title"] = "Изтрий билет"; }

<div class="row justify-content-center">
  <div class="col-md-4">
    <div class="card shadow-sm border-2 border-danger">
      <div class="card-header bg-danger text-white">
        <h5 class="mb-0"><i class="bi bi-trash me-2"></i>Изтрий билет</h5>
      </div>
      <div class="card-body">
        <p class="lead">Сигурни ли сте?</p>
        <dl class="row">
          <dt class="col-sm-4">ID:</dt><dd class="col-sm-8">@Model.Ticket.TicketId</dd>
          <dt class="col-sm-4">Цена:</dt><dd class="col-sm-8 fw-bold">@Model.Ticket.TicketPrice.ToString("F2") лв.</dd>
        </dl>
        <form method="post">
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Изтрий</button>
            <a href="/Tickets" class="btn btn-outline-secondary">Отказ</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
