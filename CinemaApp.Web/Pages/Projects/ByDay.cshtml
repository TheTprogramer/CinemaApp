@page
@model CinemaApp.Web.Pages.Projects.ByDayModel
@{ ViewData["Title"] = "Прожекции по ден"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-calendar3 me-2 text-info"></i>Прожекции по ден</h2>
    <a href="/Projects" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Обратно</a>
</div>

<form method="get" class="row g-2 mb-4">
    <div class="col-md-4">
        <select name="Day" class="form-select" onchange="this.form.submit()">
            <option value="">-- Избери ден --</option>
            @foreach (var d in CinemaApp.Web.Pages.Projects.ByDayModel.Days)
            {
                <option value="@d" selected="@(d == Model.Day)">@d</option>
            }
        </select>
    </div>
</form>

@if (!string.IsNullOrWhiteSpace(Model.Day))
{
    <div class="card shadow-sm border-0">
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead class="table-dark">
            <tr><th>Филм</th><th>Жанр</th><th>Начало</th><th>Край</th><th>Зала</th></tr>
          </thead>
          <tbody>
            @foreach (var p in Model.Projects)
            {
              <tr>
                <td class="fw-semibold">@p.Film?.FilmName</td>
                <td><span class="badge bg-info text-dark">@p.Film?.FilmGenre</span></td>
                <td>@p.StartTime</td>
                <td>@p.EndTime</td>
                <td><span class="badge bg-primary">@p.Room?.RoomType</span></td>
              </tr>
            }
            @if (!Model.Projects.Any())
            {
              <tr><td colspan="5" class="text-center text-muted py-4">Няма прожекции за @Model.Day.</td></tr>
            }
          </tbody>
        </table>
      </div>
    </div>
}
