@page "{id:int}"
@model CinemaApp.Web.Pages.Projects.DeleteModel
@{ ViewData["Title"] = "Изтрий прожекция"; }

<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card shadow-sm border-2 border-danger">
      <div class="card-header bg-danger text-white">
        <h5 class="mb-0"><i class="bi bi-trash me-2"></i>Изтрий прожекция</h5>
      </div>
      <div class="card-body">
        <p class="lead">Сигурни ли сте?</p>
        <dl class="row">
          <dt class="col-sm-4">Филм:</dt><dd class="col-sm-8 fw-bold">@Model.Project.Film?.FilmName</dd>
          <dt class="col-sm-4">Ден:</dt><dd class="col-sm-8">@Model.Project.DayOfWeek</dd>
          <dt class="col-sm-4">Час:</dt><dd class="col-sm-8">@Model.Project.StartTime – @Model.Project.EndTime</dd>
          <dt class="col-sm-4">Зала:</dt><dd class="col-sm-8">@Model.Project.Room?.RoomType</dd>
        </dl>
        <form method="post">
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Изтрий</button>
            <a href="/Projects" class="btn btn-outline-secondary">Отказ</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
