@page
@model CinemaApp.Web.Pages.Projects.ByFilmModel
@{ ViewData["Title"] = "Прожекции по филм"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-film me-2 text-info"></i>Прожекции по филм</h2>
    <a href="/Projects" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Обратно</a>
</div>

<form method="get" class="row g-2 mb-4">
    <div class="col-md-6">
        <select name="FilmName" class="form-select" onchange="this.form.submit()">
            <option value="">-- Избери филм --</option>
            @foreach (var f in Model.AllFilms)
            {
                <option value="@f.FilmName" selected="@(f.FilmName == Model.FilmName)">@f.FilmName</option>
            }
        </select>
    </div>
</form>

@if (!string.IsNullOrWhiteSpace(Model.FilmName))
{
    <div class="card shadow-sm border-0">
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead class="table-dark">
            <tr><th>Ден</th><th>Начало</th><th>Край</th><th>Зала</th></tr>
          </thead>
          <tbody>
            @foreach (var p in Model.Projects)
            {
              <tr>
                <td>@p.DayOfWeek</td>
                <td>@p.StartTime</td>
                <td>@p.EndTime</td>
                <td><span class="badge bg-primary">@p.Room?.RoomType</span></td>
              </tr>
            }
            @if (!Model.Projects.Any())
            {
              <tr><td colspan="4" class="text-center text-muted py-4">Няма прожекции за този филм.</td></tr>
            }
          </tbody>
        </table>
      </div>
    </div>
}
