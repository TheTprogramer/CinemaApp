@page "{id:int}"
@model CinemaApp.Web.Pages.Projects.DetailsModel
@{ ViewData["Title"] = "Детайли – Прожекция"; }

<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-info text-white">
        <h5 class="mb-0"><i class="bi bi-projector me-2"></i>Прожекция #@Model.Project.ProjectId</h5>
      </div>
      <div class="card-body">
        <dl class="row">
          <dt class="col-sm-4">Филм:</dt><dd class="col-sm-8 fw-bold">@Model.Project.Film?.FilmName</dd>
          <dt class="col-sm-4">Жанр:</dt><dd class="col-sm-8">@Model.Project.Film?.FilmGenre</dd>
          <dt class="col-sm-4">Ден:</dt><dd class="col-sm-8">@Model.Project.DayOfWeek</dd>
          <dt class="col-sm-4">Начало:</dt><dd class="col-sm-8">@Model.Project.StartTime</dd>
          <dt class="col-sm-4">Край:</dt><dd class="col-sm-8">@Model.Project.EndTime</dd>
          <dt class="col-sm-4">Зала:</dt>
          <dd class="col-sm-8"><span class="badge bg-primary">@Model.Project.Room?.RoomType</span></dd>
        </dl>
        <div class="d-flex gap-2 mt-3">
          <a href="/Projects/Edit/@Model.Project.ProjectId" class="btn btn-warning">
            <i class="bi bi-pencil me-1"></i>Редактирай
          </a>
          <a href="/Projects" class="btn btn-outline-secondary">Обратно</a>
        </div>
      </div>
    </div>
  </div>
</div>
