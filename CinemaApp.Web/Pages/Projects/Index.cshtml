@page
@model CinemaApp.Web.Pages.Projects.IndexModel
@{ ViewData["Title"] = "Прожекции"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-projector me-2 text-info"></i>Прожекции</h2>
    <div class="d-flex gap-2">
        <a href="/Projects/ByFilm" class="btn btn-outline-secondary">По филм</a>
        <a href="/Projects/ByDay"  class="btn btn-outline-secondary">По ден</a>
        <a href="/Projects/Create" class="btn btn-info text-white">
            <i class="bi bi-plus-circle me-1"></i>Добави
        </a>
    </div>
</div>

<div class="card shadow-sm border-0">
  <div class="card-body p-0">
    <table class="table table-hover mb-0">
      <thead class="table-dark">
        <tr><th>ID</th><th>Ден</th><th>Начало</th><th>Край</th><th>Зала</th><th>Филм</th><th class="text-end">Действия</th></tr>
      </thead>
      <tbody>
        @foreach (var p in Model.Projects)
        {
          <tr>
            <td class="text-muted">@p.ProjectId</td>
            <td>@p.DayOfWeek</td>
            <td>@p.StartTime</td>
            <td>@p.EndTime</td>
            <td><span class="badge bg-primary">@p.Room?.RoomType</span></td>
            <td>@p.Film?.FilmName</td>
            <td class="text-end">
              <a href="/Projects/Details/@p.ProjectId" class="btn btn-sm btn-outline-info me-1"><i class="bi bi-eye"></i></a>
              <a href="/Projects/Edit/@p.ProjectId"    class="btn btn-sm btn-outline-warning me-1"><i class="bi bi-pencil"></i></a>
              <a href="/Projects/Delete/@p.ProjectId"  class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
            </td>
          </tr>
        }
        @if (!Model.Projects.Any())
        {
          <tr><td colspan="7" class="text-center text-muted py-4">Няма прожекции.</td></tr>
        }
      </tbody>
    </table>
  </div>
</div>
