@page "{id:int}"
@model CinemaApp.Web.Pages.Clients.DetailsModel
@{ ViewData["Title"] = "Детайли – Клиент"; }

<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-info text-white">
        <h5 class="mb-0"><i class="bi bi-person me-2"></i>Клиент #@Model.Client.ClientId</h5>
      </div>
      <div class="card-body">
        <dl class="row">
          <dt class="col-sm-4">Ден:</dt><dd class="col-sm-8">@Model.Client.DayOfWeek</dd>
          <dt class="col-sm-4">Билет:</dt>
          <dd class="col-sm-8">#@Model.Client.TicketId — <span class="text-success fw-bold">@Model.Client.Ticket?.TicketPrice.ToString("F2") лв.</span></dd>
          <dt class="col-sm-4">Храна:</dt>
          <dd class="col-sm-8">@Model.Client.Food?.FoodTitle <span class="badge bg-secondary">@Model.Client.Food?.Type?.TypeTitle — @Model.Client.Food?.Type?.TypePrice.ToString("F2") лв.</span></dd>
          <dt class="col-sm-4">Напитка:</dt>
          <dd class="col-sm-8">@Model.Client.Drink?.DrinkTitle <span class="badge bg-secondary">@Model.Client.Drink?.Type?.TypeTitle — @Model.Client.Drink?.Type?.TypePrice.ToString("F2") лв.</span></dd>
          <dt class="col-sm-4">Общо:</dt>
          <dd class="col-sm-8 fw-bold text-success fs-5">
            @(((Model.Client.Ticket?.TicketPrice ?? 0) +
               (Model.Client.Food?.Type?.TypePrice ?? 0) +
               (Model.Client.Drink?.Type?.TypePrice ?? 0)).ToString("F2")) лв.
          </dd>
        </dl>
        <div class="d-flex gap-2 mt-3">
          <a href="/Clients/Edit/@Model.Client.ClientId" class="btn btn-warning">
            <i class="bi bi-pencil me-1"></i>Редактирай
          </a>
          <a href="/Clients" class="btn btn-outline-secondary">Обратно</a>
        </div>
      </div>
    </div>
  </div>
</div>
