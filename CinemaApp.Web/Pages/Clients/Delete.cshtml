@page "{id:int}"
@model CinemaApp.Web.Pages.Clients.DeleteModel
@{ ViewData["Title"] = "Изтрий клиент"; }

<div class="row justify-content-center">
  <div class="col-md-5">
    <div class="card shadow-sm border-2 border-danger">
      <div class="card-header bg-danger text-white">
        <h5 class="mb-0"><i class="bi bi-trash me-2"></i>Изтрий клиент</h5>
      </div>
      <div class="card-body">
        <p class="lead">Сигурни ли сте?</p>
        <dl class="row">
          <dt class="col-sm-4">ID:</dt><dd class="col-sm-8">@Model.Client.ClientId</dd>
          <dt class="col-sm-4">Ден:</dt><dd class="col-sm-8 fw-bold">@Model.Client.DayOfWeek</dd>
          <dt class="col-sm-4">Билет:</dt><dd class="col-sm-8">#@Model.Client.TicketId — @Model.Client.Ticket?.TicketPrice.ToString("F2") лв.</dd>
          <dt class="col-sm-4">Храна:</dt><dd class="col-sm-8">@Model.Client.Food?.FoodTitle</dd>
          <dt class="col-sm-4">Напитка:</dt><dd class="col-sm-8">@Model.Client.Drink?.DrinkTitle</dd>
        </dl>
        <form method="post">
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Изтрий</button>
            <a href="/Clients" class="btn btn-outline-secondary">Отказ</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
