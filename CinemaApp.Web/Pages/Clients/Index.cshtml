@page
@model CinemaApp.Web.Pages.Clients.IndexModel
@{ ViewData["Title"] = "Клиенти"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-people me-2 text-warning"></i>Клиенти</h2>
    <div class="d-flex gap-2">
        <a href="/Clients/Queries" class="btn btn-outline-info">
            <i class="bi bi-bar-chart me-1"></i>Справки
        </a>
        <a href="/Clients/Create" class="btn btn-warning">
            <i class="bi bi-plus-circle me-1"></i>Добави
        </a>
    </div>
</div>

<div class="card shadow-sm border-0">
  <div class="card-body p-0">
    <table class="table table-hover mb-0">
      <thead class="table-dark">
        <tr><th>ID</th><th>Ден</th><th>Билет</th><th>Цена</th><th>Храна</th><th>Напитка</th><th class="text-end">Действия</th></tr>
      </thead>
      <tbody>
        @foreach (var c in Model.Clients)
        {
          <tr>
            <td class="text-muted">@c.ClientId</td>
            <td>@c.DayOfWeek</td>
            <td class="text-muted">#@c.TicketId</td>
            <td><span class="badge bg-success">@c.Ticket?.TicketPrice.ToString("F2") лв.</span></td>
            <td>@c.Food?.FoodTitle <span class="text-muted small">(@c.Food?.Type?.TypeTitle)</span></td>
            <td>@c.Drink?.DrinkTitle <span class="text-muted small">(@c.Drink?.Type?.TypeTitle)</span></td>
            <td class="text-end">
              <a href="/Clients/Details/@c.ClientId" class="btn btn-sm btn-outline-info me-1"><i class="bi bi-eye"></i></a>
              <a href="/Clients/Edit/@c.ClientId"    class="btn btn-sm btn-outline-warning me-1"><i class="bi bi-pencil"></i></a>
              <a href="/Clients/Delete/@c.ClientId"  class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
            </td>
          </tr>
        }
        @if (!Model.Clients.Any())
        {
          <tr><td colspan="7" class="text-center text-muted py-4">Няма клиенти.</td></tr>
        }
      </tbody>
    </table>
  </div>
</div>
