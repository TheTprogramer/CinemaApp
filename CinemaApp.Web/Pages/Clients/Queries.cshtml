@page
@model CinemaApp.Web.Pages.Clients.QueriesModel
@{ ViewData["Title"] = "Справки"; }

<h2 class="mb-4"><i class="bi bi-bar-chart-line me-2 text-info"></i>Справки</h2>

<div class="row g-4">

    @* ── Продадени билети за ден ──────────────────────────────────── *@
    <div class="col-md-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-primary text-white">
                <h6 class="mb-0"><i class="bi bi-ticket-perforated me-2"></i>Продадени билети за ден</h6>
            </div>
            <div class="card-body">
                <form method="get">
                    <input type="hidden" name="QueryType" value="sold" />
                    <div class="input-group">
                        <select name="Day" class="form-select" asp-items="Model.DaysList">
                            <option value="">-- Избери ден --</option>
                        </select>
                        <button class="btn btn-primary" type="submit">Търси</button>
                    </div>
                </form>
                @if (Model.QueryType == "sold" && Model.SoldCount.HasValue)
                {
                    <div class="alert alert-primary mt-3 mb-0">
                        <strong>@Model.Day:</strong> <span class="fs-4">@Model.SoldCount</span> продадени билети
                    </div>
                }
            </div>
        </div>
    </div>

    @* ── Приходи за ден ───────────────────────────────────────────── *@
    <div class="col-md-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-success text-white">
                <h6 class="mb-0"><i class="bi bi-cash-coin me-2"></i>Приходи за ден</h6>
            </div>
            <div class="card-body">
                <form method="get">
                    <input type="hidden" name="QueryType" value="revenue_day" />
                    <div class="input-group">
                        <select name="Day" class="form-select" asp-items="Model.DaysList">
                            <option value="">-- Избери ден --</option>
                        </select>
                        <button class="btn btn-success" type="submit">Търси</button>
                    </div>
                </form>
                @if (Model.QueryType == "revenue_day" && Model.Revenue.HasValue)
                {
                    <div class="alert alert-success mt-3 mb-0">
                        <strong>@Model.Day:</strong> <span class="fs-4">@Model.Revenue.Value.ToString("F2") лв.</span>
                    </div>
                }
            </div>
        </div>
    </div>

    @* ── Приходи за седмицата ─────────────────────────────────────── *@
    <div class="col-md-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-warning text-dark">
                <h6 class="mb-0"><i class="bi bi-graph-up-arrow me-2"></i>Приходи за седмицата</h6>
            </div>
            <div class="card-body">
                <form method="get">
                    <input type="hidden" name="QueryType" value="revenue_week" />
                    <button class="btn btn-warning w-100" type="submit">
                        <i class="bi bi-calculator me-1"></i>Изчисли
                    </button>
                </form>
                @if (Model.QueryType == "revenue_week" && Model.WeeklyRevenue.HasValue)
                {
                    <div class="alert alert-warning mt-3 mb-0">
                        Общо за седмицата: <span class="fs-4 fw-bold">@Model.WeeklyRevenue.Value.ToString("F2") лв.</span>
                    </div>
                }
            </div>
        </div>
    </div>

    @* ── Клиенти с еднакви разходи ────────────────────────────────── *@
    <div class="col-md-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-secondary text-white">
                <h6 class="mb-0"><i class="bi bi-people me-2"></i>Клиенти с еднакви разходи</h6>
            </div>
            <div class="card-body">
                <form method="get">
                    <input type="hidden" name="QueryType" value="same_expenses" />
                    <button class="btn btn-secondary w-100" type="submit">
                        <i class="bi bi-search me-1"></i>Покажи
                    </button>
                </form>
                @if (Model.QueryType == "same_expenses" && Model.SameExpenses.Any())
                {
                    <table class="table table-sm mt-3 mb-0">
                        <thead class="table-dark">
                            <tr><th>Разход (лв.)</th><th>Брой клиенти</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var (expenses, count) in Model.SameExpenses)
                            {
                                <tr>
                                    <td>@expenses.ToString("F2")</td>
                                    <td><span class="badge bg-secondary">@count</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else if (Model.QueryType == "same_expenses")
                {
                    <div class="alert alert-secondary mt-3 mb-0">Няма клиенти с еднакви разходи.</div>
                }
            </div>
        </div>
    </div>

</div>
